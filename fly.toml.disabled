# ⚠️ 사용 중지 (2026-07-02) — gomdori-mcp 통합 호스트가 korean-law-mcp 앱을 점유 중.
# 여기서 deploy하면 통합 이미지가 덮여 MCP 5종 전부 죽는다. 배포는 .claude/commands/deploy.md 절차로.
# fly.toml app configuration file generated for korean-law-mcp on 2026-01-18T12:11:34+09:00
#
# See https://fly.io/docs/reference/configuration/ for information about how to use this file.
#

app = 'korean-law-mcp'
primary_region = 'nrt'

[build]
  dockerfile = 'Dockerfile'

[env]
  NODE_ENV = 'production'
  PORT = '3000'
  RATE_LIMIT_RPM = '300'

[http_service]
  internal_port = 3000
  force_https = true
  auto_stop_machines = 'suspend'
  auto_start_machines = true
  min_machines_running = 0

[[vm]]
  memory = '256mb'
  cpu_kind = 'shared'
  cpus = 1
  memory_mb = 256
